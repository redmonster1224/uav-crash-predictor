import pandas as pd
import matplotlib.pyplot as plt

# Assuming df is your parsed telemetry dataframe from src/data_parser.py
# For demonstration, let's plot Pitch, Roll, and Motor RPM over time

def plot_flight_dynamics(df, title="UAV Flight Telemetry"):
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8), sharex=True)
    
    # Plot 1: Attitude (Pitch and Roll)
    ax1.plot(df['timestamp'], df['pitch'], label='Pitch', color='blue', alpha=0.7)
    ax1.plot(df['timestamp'], df['roll'], label='Roll', color='orange', alpha=0.7)
    ax1.set_ylabel('Degrees / Radians')
    ax1.set_title(f'{title} - Attitude')
    ax1.legend()
    ax1.grid(True)
    
    # Plot 2: Motor RPM (or Battery Voltage)
    ax2.plot(df['timestamp'], df['battery_voltage'], label='Battery (V)', color='red')
    ax2.set_ylabel('Voltage')
    ax2.set_xlabel('Timestamp')
    ax2.legend()
    ax2.grid(True)
    
    plt.tight_layout()
    plt.show()

